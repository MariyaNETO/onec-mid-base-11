#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	// НЕТО - НачалоИзменений: Пересчитать сумму строк с учетом сыммы скидок 
	// КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	// ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	
	СуммаСкидок = Объект.НЕТО_СогласованнаяСкидка + ТекущиеДанные.Скидка;
	
	Если СуммаСкидок > 100 Тогда
		
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = ("Сумма скидок больше или равна 100%! Необходимо уменьшить скидку!");
		Сообщение.Сообщить();
		
		ТекущиеДанные.Сумма = 0;
		Возврат;
	Иначе
		КоэффициентСкидки = 1 - СуммаСкидок / 100;
		ТекущиеДанные.Сумма = ТекущиеДанные.Цена * КоэффициентСкидки * ТекущиеДанные.Количество;
	КонецЕсли;
	РассчитатьСуммуДокумента();
	
	//НЕТО - КонецИзменений
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

