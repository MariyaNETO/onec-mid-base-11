#Область НЕТО_СлужебныеПроцедурыИФункции 

&НаКлиенте
Процедура НЕТО_ПересчитатьТаблицу(Команда) 
	
	//Нетология - НачалоИзменений
	//Пересчитать таблицу с учетом скидки при нажатии на кнопку
	//Сообщить("нет!!!");
	НЕТО_ПересчитатьСтрокиТабличныхЧастей();
	//Нетология - КонецИзменений
	
КонецПроцедуры


&НаКлиенте
Асинх Процедура НЕТО_НЕТО_СогласованнаяСкидкаПриИзменении(Элемент)
	
	//Нетология - НачалоИзменений
	//Задать вопрос при изменении и пересчитать таблицу
	//Проверить заполнение табличных частей и пересчитать таблицы
	Если Не ЗначениеЗаполнено(Объект.Товары) И Не ЗначениеЗаполнено(Объект.Услуги) Тогда
		Возврат;
	КонецЕсли;

	Вопрос = ВопросАсинх("Изменен процент скидки. Пересчитать таблицу товаров и услуг?", РежимДиалогаВопрос.ДаНет);
	ОтветНаВопрос = Ждать Вопрос;
	
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		
		НЕТО_ПересчитатьСтрокиТабличныхЧастей();
		
	КонецЕсли;
	//Нетология - КонецИзменений
	
КонецПроцедуры 

&НаКлиенте
Процедура НЕТО_ПересчитатьСтрокиТабличныхЧастей()
	
	//НЕТО - НачалоИзменений
		
	Для Каждого Строка Из Объект.Товары Цикл
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;
	
	Для Каждого Строка Из Объект.Услуги Цикл
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;
	//НЕТО - КонецИзменений
	
КонецПроцедуры


#КонецОбласти

